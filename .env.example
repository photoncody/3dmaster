# Environment
AUTH_ENABLED=false
AUTH_SECRET=generate-a-long-random-string
DATA_DIR=./data
# Prefer absolute file: URLs in production (e.g. file:/data/3dmaster.db).
# Relative paths are resolved from the process working directory.
DATABASE_URL=file:./data/3dmaster.db

# Bootstrap local admin (used when AUTH_ENABLED=true)
# AUTH_BOOTSTRAP_USER=admin
# AUTH_BOOTSTRAP_PASSWORD=change-me

# Generic OIDC (Authentik, Keycloak, etc.)
# OIDC_ISSUER=https://idp.example.com/application/o/3dmaster/
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_GROUP_CLAIM=groups
# OIDC_ALLOWED_GROUPS=3d-printers

# Public URL when behind a reverse proxy (Auth.js)
# AUTH_URL=https://3dmaster.example.com
# AUTH_TRUST_HOST=true

# Upload limit (bytes)
# MAX_UPLOAD_BYTES=209715200

# Age color thresholds (days)
# DRY_GREEN_DAYS=3
# DRY_YELLOW_DAYS=7
# DRY_ORANGE_DAYS=14
# CLEAN_GREEN_DAYS=7
# CLEAN_YELLOW_DAYS=14
# CLEAN_ORANGE_DAYS=30
