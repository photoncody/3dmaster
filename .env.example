# Environment
AUTH_ENABLED=false
# Required when AUTH_ENABLED=true. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Required to run with AUTH_ENABLED=false in production.
# ALLOW_INSECURE_NO_AUTH=true
# Disable username/password auth when using OIDC only.
# AUTH_CREDENTIALS_ENABLED=true
DATA_DIR=./data
# Prisma CLI resolves relative file: URLs from the prisma/ schema directory.
# MUST be absolute for Prisma CLI reliability, e.g.:
# DATABASE_URL=file:/absolute/path/to/data/3dmaster.db
# Wrong: file:./data/3dmaster.db (migrates prisma/data/ when using Prisma CLI)
DATABASE_URL=file:./data/3dmaster.db

# Bootstrap local admin (used when AUTH_ENABLED=true)
# AUTH_BOOTSTRAP_USER=admin
# AUTH_BOOTSTRAP_PASSWORD=change-me

# Generic OIDC (Authentik, Keycloak, etc.)
# OIDC_ISSUER=https://idp.example.com/application/o/3dmaster/
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_GROUP_CLAIM=groups
# OIDC_ALLOWED_GROUPS=3d-printers
# OIDC_ALLOW_ALL_GROUPS=false

# Public URL when behind a reverse proxy (Auth.js)
# AUTH_URL=https://3dmaster.example.com
# AUTH_TRUST_HOST=true
# Trust X-Forwarded-For/X-Real-IP only when a reverse proxy controls them.
# TRUST_PROXY=true

# Upload limit (bytes)
# MAX_UPLOAD_BYTES=209715200

# Age color thresholds (days)
# DRY_GREEN_DAYS=3
# DRY_YELLOW_DAYS=7
# DRY_ORANGE_DAYS=14
# CLEAN_GREEN_DAYS=7
# CLEAN_YELLOW_DAYS=14
# CLEAN_ORANGE_DAYS=30
